<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AR Quest Extreme - Monolithic</title>
    <style>
        :root {
            --glass: rgba(0, 0, 0, 0.4);
            --glass-border: rgba(255, 255, 255, 0.2);
            --accent: #00f2ff;
            --bg-deep: #000;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: black;
            color: white;
            overflow: hidden;
            width: 100vw;
            height: 100vh;
            position: fixed;
        }

        #video-bg {
            position: absolute;
            top: 50%;
            left: 50%;
            min-width: 100%;
            min-height: 100%;
            width: auto;
            height: auto;
            transform: translate(-50%, -50%);
            object-fit: cover;
            z-index: 0;
        }

        #canvas-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        #hud {
            position: absolute;
            inset: 0;
            z-index: 10;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 1.5rem;
        }

        .hud-panel {
            background: var(--glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 1rem;
            pointer-events: auto;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            width: 100%;
            gap: 1rem;
        }

        .stat-panel {
            flex: 1;
            max-width: 180px;
        }

        .stat-panel.right {
            text-align: right;
            max-width: 120px;
        }

        .hud-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            opacity: 0.7;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .hud-value {
            font-size: 24px;
            font-weight: 900;
            color: var(--accent);
        }

        #timer.warning {
            color: #f43f5e;
        }

        .bottom-bar {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            width: 100%;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .scan-icon {
            width: 36px;
            height: 36px;
            background: rgba(0, 242, 255, 0.1);
            border: 1px solid rgba(0, 242, 255, 0.3);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            font-weight: 900;
            color: var(--accent);
        }

        .radar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .radar-circle {
            width: 60px;
            height: 60px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            position: relative;
        }

        .radar-sweep {
            position: absolute;
            inset: 0;
            border-top: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 50%;
            animation: spin 4s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        #overlay {
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 2.5rem;
            width: 100%;
            max-width: 360px;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .card-icon {
            width: 80px;
            height: 80px;
            background: rgba(0, 242, 255, 0.1);
            border: 1px solid rgba(0, 242, 255, 0.3);
            border-radius: 20px;
            margin: 0 auto 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            box-shadow: 0 0 20px rgba(0, 242, 255, 0.2);
        }

        h1 {
            font-size: 32px;
            font-weight: 900;
            letter-spacing: -1px;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .card p {
            font-size: 14px;
            opacity: 0.6;
            line-height: 1.5;
            margin-bottom: 2rem;
        }

        .btn {
            background: var(--accent);
            color: var(--bg-deep);
            border: none;
            width: 100%;
            padding: 1.25rem;
            border-radius: 16px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 0 20px rgba(0, 242, 255, 0.4);
        }

        .btn:active {
            transform: scale(0.95);
        }

        .error-msg {
            background: rgba(244, 63, 94, 0.1);
            border: 1px solid rgba(244, 63, 94, 0.3);
            color: #fb7185;
            padding: 1rem;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 1.5rem;
            display: none;
        }

        #reticle {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 60px;
            height: 60px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            pointer-events: none;
            z-index: 20;
        }

        #reticle::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 4px;
            height: 4px;
            background: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--accent);
        }
    </style>
</head>
<body>
    <video id="video-bg" autoplay playsinline muted></video>
    <div id="canvas-container"></div>
    
    <div id="reticle"></div>

    <div id="hud">
        <div class="top-bar">
            <div class="hud-panel stat-panel">
                <div class="hud-label">Puntuación</div>
                <div id="score" class="hud-value">0</div>
            </div>
            <div class="hud-panel stat-panel right">
                <div class="hud-label">Tiempo</div>
                <div id="timer" class="hud-value">00:45</div>
            </div>
        </div>

        <div class="bottom-bar">
            <div class="hud-panel status-badge">
                <div class="scan-icon">SCAN</div>
                <div>
                    <div class="hud-label" style="margin:0">Estado</div>
                    <div style="font-size: 10px; font-weight: 700; text-transform: uppercase;">VR Quest Activo</div>
                </div>
            </div>
            <div class="hud-panel radar">
                <div class="radar-circle">
                    <div class="radar-sweep"></div>
                </div>
            </div>
        </div>
    </div>

    <div id="overlay">
        <div class="card">
            <div class="card-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <h1 id="title">VR Quest</h1>
            <p id="description">Explora el vacío y atrapa las anomalías flotantes. Necesitarás mover tu dispositivo para mirar a tu alrededor.</p>
            
            <div id="error-box" class="error-msg"></div>

            <div id="score-summary" style="display: none; margin-bottom: 1.5rem;">
                <div class="hud-label">Misión Completada</div>
                <div id="final-score" class="hud-value" style="font-size: 48px;">0</div>
            </div>

            <button id="start-btn" class="btn">Iniciar Escaneo</button>
        </div>
    </div>

    <!-- Importing Three.js from CDN -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';

        // Game State
        const state = {
            score: 0,
            timeLeft: 45,
            isPlaying: false,
            orbs: []
        };

        // THREE variables
        let scene, camera, renderer, globe, orbsGroup;
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();

        // DOM elements
        const scoreEl = document.getElementById('score');
        const timerEl = document.getElementById('timer');
        const startBtn = document.getElementById('start-btn');
        const overlay = document.getElementById('overlay');
        const finalScoreEl = document.getElementById('final-score');
        const summaryEl = document.getElementById('score-summary');
        const errorBox = document.getElementById('error-box');

        function init() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            
            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            // Light
            const ambient = new THREE.AmbientLight(0xffffff, 0.8);
            scene.add(ambient);

            const point = new THREE.PointLight(0xffffff, 1);
            point.position.set(10, 10, 10);
            scene.add(point);

            orbsGroup = new THREE.Group();
            scene.add(orbsGroup);

            window.addEventListener('resize', onWindowResize);
            
            // Touch interaction
            window.addEventListener('touchstart', onTouchInteraction);
            window.addEventListener('mousedown', onMouseInteraction);

            animate();
        }

        function spawnObject() {
            const geometries = [
                new THREE.SphereGeometry(0.5, 32, 32),
                new THREE.BoxGeometry(0.7, 0.7, 0.7),
                new THREE.ConeGeometry(0.5, 1, 32),
                new THREE.TorusGeometry(0.4, 0.15, 16, 100),
                new THREE.OctahedronGeometry(0.6),
                new THREE.DodecahedronGeometry(0.6),
                new THREE.TorusKnotGeometry(0.3, 0.1, 64, 8)
            ];

            const geometry = geometries[Math.floor(Math.random() * geometries.length)];
            const material = new THREE.MeshStandardMaterial({
                color: new THREE.Color(`hsl(${Math.random() * 360}, 80%, 65%)`),
                emissive: new THREE.Color('#00f2ff'),
                emissiveIntensity: 0.4,
                metalness: 0.9,
                roughness: 0.1
            });
            const object = new THREE.Mesh(geometry, material);
            
            const distance = 5 + Math.random() * 7;
            const theta = Math.random() * Math.PI * 2;
            const phi = (Math.random() - 0.5) * Math.PI;

            object.position.x = distance * Math.cos(phi) * Math.sin(theta);
            object.position.y = distance * Math.sin(phi);
            object.position.z = distance * Math.cos(phi) * Math.cos(theta);

            // Random rotation speed for uniqueness
            object.userData.rotSpeed = {
                x: (Math.random() - 0.5) * 0.05,
                y: (Math.random() - 0.5) * 0.05,
                z: (Math.random() - 0.5) * 0.05
            };

            orbsGroup.add(object);
        }

        function handleOrientation(e) {
            if (!state.isPlaying) return;
            const alpha = e.alpha ? THREE.MathUtils.degToRad(e.alpha) : 0;
            const beta = e.beta ? THREE.MathUtils.degToRad(e.beta) : 0;
            const gamma = e.gamma ? THREE.MathUtils.degToRad(e.gamma) : 0;

            // Simplified Euler for phone rotation
            // YXZ order is standard for device orientation
            const euler = new THREE.Euler(beta, alpha, -gamma, 'YXZ');
            camera.quaternion.setFromEuler(euler);
        }

        async function startGame() {
            errorBox.style.display = 'none';
            
            // Camera Access
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: 'environment' } 
                });
                const video = document.getElementById('video-bg');
                video.srcObject = stream;
            } catch (e) {
                console.warn("Camera failed, using black background", e);
            }

            // Permissions for iOS
            if (typeof DeviceOrientationEvent !== 'undefined' && typeof DeviceOrientationEvent.requestPermission === 'function') {
                try {
                    const response = await DeviceOrientationEvent.requestPermission();
                    if (response === 'granted') {
                        window.addEventListener('deviceorientation', handleOrientation);
                    } else {
                        showError("Permiso de sensores denegado.");
                        return;
                    }
                } catch (e) {
                    showError("Error al solicitar sensores.");
                    return;
                }
            } else if (window.DeviceOrientationEvent) {
                window.addEventListener('deviceorientation', handleOrientation);
            } else {
                showError("Dispositivo no compatible con sensores.");
                return;
            }

            state.score = 0;
            state.timeLeft = 45;
            state.isPlaying = true;
            scoreEl.textContent = '0';
            overlay.style.display = 'none';

            // Clear and spawn
            while(orbsGroup.children.length > 0) orbsGroup.remove(orbsGroup.children[0]);
            
            // Increased count to 40 objects for extreme mode
            for(let i = 0; i < 40; i++) spawnObject();

            // Timer interval
            const timerInterval = setInterval(() => {
                state.timeLeft--;
                const mins = Math.floor(state.timeLeft / 60).toString().padStart(2, '0');
                const secs = (state.timeLeft % 60).toString().padStart(2, '0');
                timerEl.textContent = `${mins}:${secs}`;
                
                if (state.timeLeft < 10) timerEl.classList.add('warning');
                else timerEl.classList.remove('warning');

                if (state.timeLeft <= 0) {
                    clearInterval(timerInterval);
                    endGame();
                }
            }, 1000);
        }

        function endGame() {
            state.isPlaying = false;
            overlay.style.display = 'flex';
            summaryEl.style.display = 'block';
            finalScoreEl.textContent = state.score;
            document.getElementById('title').textContent = 'Secuencia Finalizada';
            document.getElementById('description').textContent = 'Escaneo completado con éxito.';
            startBtn.textContent = 'Reiniciar Sistema';
        }

        function showError(msg) {
            errorBox.textContent = msg;
            errorBox.style.display = 'block';
        }

        function checkHit(x, y) {
            if (!state.isPlaying) return;
            
            mouse.x = (x / window.innerWidth) * 2 - 1;
            mouse.y = -(y / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(orbsGroup.children);

            if (intersects.length > 0) {
                const orb = intersects[0].object;
                orbsGroup.remove(orb);
                state.score += 10;
                scoreEl.textContent = state.score;
                spawnObject();

                // Haptic
                if (navigator.vibrate) navigator.vibrate(40);
            }
        }

        function onTouchInteraction(e) {
            if (e.target === startBtn) return;
            checkHit(e.touches[0].clientX, e.touches[0].clientY);
        }

        function onMouseInteraction(e) {
            if (e.target === startBtn) return;
            checkHit(e.clientX, e.clientY);
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            
            // Visual rotation for objects
            orbsGroup.children.forEach(obj => {
                obj.rotation.x += obj.userData.rotSpeed.x;
                obj.rotation.y += obj.userData.rotSpeed.y;
                obj.rotation.z += obj.userData.rotSpeed.z;
            });

            renderer.render(scene, camera);
        }

        // Event Listeners
        startBtn.addEventListener('click', startGame);
        startBtn.addEventListener('touchstart', (e) => {
            e.preventDefault();
            startGame();
        });

        // Autostart init
        init();

    </script>
</body>
</html>
